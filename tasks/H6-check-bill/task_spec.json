  "goal": "Login to utility portal, check current electricity and water bill amounts and due dates",
  "inputs": {
    "utility_types": [
      "electricity",
      "water"
    ]
  },
  "allowed_domains": [
    "gov.local"
  ],
  "preconditions": [
    "mem('identity.address') != ''"
  ],
  "memory_keys": [
    "bills.electricity.amount",

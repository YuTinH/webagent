{
  "version": 1,
  "dataset": {
    "min_multi_path_ratio": 0.5
  },
  "soft_quality": {
    "max_subset_like_multi_path_ratio": 0.3,
    "max_initial_target_overlap_ratio": 0.0,
    "enforce_subset_like_as_hard": true,
    "enforce_initial_target_overlap_as_hard": true
  },
  "multi_path": {
    "min_success_paths": 2,
    "min_semantically_distinct_paths": 2,
    "require_distinct_required_module_sets": true,
    "max_required_set_jaccard": 0.8
  },
  "single_path": {
    "max_success_paths": 1,
    "required_declared_distinct_paths": 1
  },
  "semantic_distinctness": {
    "must_vary_by": [
      "module_set",
      "key_resource_path",
      "dependency_structure",
      "intermediate_shared_state"
    ],
    "not_sufficient_by_themselves": [
      "parameter_change_only",
      "minor_order_swap_only",
      "module_alias_only"
    ]
  },
  "realism": {
    "contexts": {
      "order_support": {
        "enabled": true,
        "order_context_any_of": [
          "shop_order_exists",
          "shop_order_delivered"
        ],
        "delivered_order_required_modules": [
          "MODULE_RETURN",
          "MODULE_WARRANTY_CLAIM",
          "MODULE_LEAVE_REVIEW",
          "MODULE_REVIEWS_BLACKLIST"
        ],
        "forbid_order_bootstrap_modules": [
          "MODULE_BANK_OPENING",
          "MODULE_SHOPPING"
        ],
        "forbid_subscription_bootstrap_modules": [
          "MODULE_FRESH_SUBSCRIPTION"
        ],
        "subscription_context_required": [
          "subscription_active"
        ]
      },
      "bank_account_issue": {
        "enabled": true,
        "issue_modules": [
          "MODULE_CARD_REPLACEMENT",
          "MODULE_DISPUTE_TRANSACTION",
          "MODULE_CHECK_BALANCE",
          "MODULE_LOST_CARD_FREEZE",
          "MODULE_URGENT_LOAN"
        ],
        "bootstrap_module": "MODULE_BANK_OPENING",
        "required_account_context": [
          "bank_account_active"
        ],
        "bootstrap_allowed_target_predicates": [
          "bank_account_active"
        ]
      },
      "travel_booking": {
        "enabled": true,
        "booking_context_any_of": [
          "flight_booked",
          "travel_booking_confirmed"
        ],
        "booking_bootstrap_modules": [
          "MODULE_BOOK_FLIGHT",
          "MODULE_LONG_HAUL_TRIP"
        ],
        "requires_booking_modules": [
          "MODULE_FLIGHT_REBOOKING",
          "MODULE_CHECK_IN"
        ]
      }
    },
    "themes": {
      "career": {
        "enabled": true
      },
      "composite": {
        "enabled": true
      },
      "crisis": {
        "enabled": true
      },
      "daily": {
        "enabled": true
      },
      "education": {
        "enabled": true
      },
      "finance": {
        "enabled": true
      },
      "government": {
        "enabled": true
      },
      "health": {
        "enabled": true
      },
      "home": {
        "enabled": true
      },
      "newcomer": {
        "enabled": true
      },
      "security": {
        "enabled": true
      },
      "social": {
        "enabled": true
      },
      "support": {
        "enabled": true
      },
      "travel": {
        "enabled": true
      }
    }
  }
}
